{
    "mcpServers": {
        "FileSystemMCP": {
            "command": "python",
            "args": [
                "./McpServers/FileSystemMCP.py"
            ]
        },
        "WebSearchMCP": {
            "command": "python",
            "args": [
                "./McpServers/WebSearchMCP.py"
            ]
        },
        "MemoryMCP": {
            "command": "python",
            "args": [
                "-m", "memory.McpServers.MemoryMCP"
            ],
            "env": {
                "MCP_DEFAULT_ENTITY_ID": ""
            }
        }
    }
}