# ─────────────────────────────────────────────────────────
# ClingySOCKs — Self-Hosted Configuration
# ─────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# Only DATABASE_URL and at least one LLM API key are required.



# Edition controls which features are enabled:
#   "community" = core memory + chat + harvest + TTS (default)
#   "standard"  = + mood, decay, preferences, graph
#   "pro"       = + dreams, imperfection, heartbeat, agent tasks
#   "full"      = everything
EDITION=community

# ── Database (REQUIRED) ──────────────────────────────────
# PostgreSQL with pgvector extension.
# Railway: Use the $DATABASE_URL variable from your Railway PostgreSQL service.
DATABASE_URL=postgresql://user:password@localhost:5432/clingysocks_memory

# ── Security ─────────────────────────────────────────────
# API key for backend access (leave empty to disable auth in dev)
MEMORY_API_KEY=

# JWT secret for local auth tokens (auto-generated if empty, set for production)
JWT_SECRET=

# Encryption key for API keys stored in DB (64 hex chars or passphrase)
ENCRYPTION_KEY=

# Set to true to refuse startup without ENCRYPTION_KEY and JWT_SECRET
# REQUIRE_SECRETS=false

# ── LLM API Keys ────────────────────────────────────────
# Set at least one. You can also add keys via the Settings UI.
# GEMINI_API_KEY=your-gemini-key
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
# XAI_API_KEY=your-xai-key
# OPENROUTER_API_KEY=your-openrouter-key

# ── Model Configuration (OPTIONAL — harvest auto-picks a cheap model) ────
# By DEFAULT you do NOT need to set these. The harvest pipeline runs in the
# BACKGROUND and automatically uses a cheap-but-capable model derived from each
# persona's CHAT provider (reusing the same key chat already uses):
#     chat gemini/*  → harvest gemini/gemini-2.5-flash
#     chat openai/*  → harvest openai/gpt-4o-mini      (not the pricey gpt-4o)
#     chat claude/*  → harvest anthropic/claude-haiku-4-5
#     chat grok/*    → harvest xai/grok-2-1212
#     chat openrouter/* → harvest openrouter/openai/gpt-4o-mini
#     chat local/*   → harvest the SAME local model (free)
# So if chat works, harvest works — and cheaply. Leave these unset unless you
# want to PIN a specific model for all personas (power-user override). Setting
# them forces that exact model regardless of the persona's provider.
#
# ⚠️  LM Studio users: LM Studio loads one model at a time, so a local chat model
#     already reuses itself for harvest (no thrash). Only pin these if you run a
#     separate inference instance for the pipeline.
# NARRATIVE_MODEL=gemini/gemini-2.5-flash
# EXTRACTION_MODEL=gemini/gemini-2.5-flash
# SYNTHESIS_MODEL=gemini/gemini-2.5-flash

# ── Harvest LLM resilience / rate limiting ──────────────
# Every harvest pass routes through a wrapper (src/pipeline/llm_client.py) that
# applies a per-call timeout, retry-with-backoff on transient errors
# (429 / 5xx / timeout), and an optional throttle. This is the main defense
# against a harvest "stopping partway" on a flaky provider call. Retries (not
# pacing) are the primary rate-limit defense — fine for paid tiers. On a strict
# free tier, set LLM_MIN_REQUEST_INTERVAL > 0 to space calls out preemptively.
# LLM_MAX_RETRIES=4              # retries per call on transient failures
# LLM_TIMEOUT_SECONDS=120        # fallback per-call timeout (passes set their own)
# LLM_MAX_CONCURRENCY=1          # max in-flight calls; keep at 1 to stay sequential
# LLM_MIN_REQUEST_INTERVAL=0.0   # min seconds between call launches (0 = no throttle)
# LLM_RETRY_BASE_DELAY=2.0       # exponential backoff base (seconds)
# LLM_RETRY_MAX_DELAY=60.0       # backoff ceiling (also clamps server Retry-After hints)

# ── Harvest pass toggles & cost bounds ──────────────────
# Each enabled pass is an extra billed LLM call. Toggle off for a cheaper run.
# ECHO_ENABLED=true              # "dream" generation on silence gaps
# FACTUAL_ENABLED=true           # knowledge-graph entity extraction (1 call/chunk)
# Cap existing entities injected into the factual prompt as dedup hints. Code-side
# dedup still uses ALL entities — this only bounds prompt size as the graph grows.
# FACTUAL_DEDUP_HINT_LIMIT=150
# Cap items per type sent to the edge-building LLM (most-recent first), to bound
# the prompt as total memory grows. 0 = send the entire memory (legacy).
# EDGE_MAX_ITEMS_PER_TYPE=50

# ── TTS (Optional) ──────────────────────────────────────
# ELEVENLABS_API_KEY=your-elevenlabs-key
# GOOGLE_TTS_API_KEY=your-google-tts-key
# LOCAL_TTS_URL=http://localhost:8880

# ── Web Search (Optional — powers the WebSearchMCP tool) ─
# Lets the agent search the web and fetch pages. Set ONE provider key.
# If no key is set, the search tool returns a "not configured" message
# (page fetching via fetch_webpage still works without a key).
# Provider selection (exa | tavily | brave | serpapi). Exa is recommended.
# SEARCH_PROVIDER=exa
# EXA_API_KEY=your-exa-key
# TAVILY_API_KEY=your-tavily-key
# BRAVE_SEARCH_API_KEY=your-brave-key
# SERPAPI_KEY=your-serpapi-key

# ── Pipeline Settings ───────────────────────────────────
MAX_CHUNK_CHARS=50000
TIME_GAP_HOURS=6
MAX_OUTPUT_TOKENS=16384

# ── Embedding (Optional — enables semantic search) ──────
# ⚠️  LM Studio users: see note above NARRATIVE_MODEL. If EMBEDDING_MODEL
#     points at a local embedder while your chat persona uses a different
#     local model, LM Studio will unload the chat model to load the embedder
#     after every harvest. Either disable embeddings, use an API-hosted
#     embedder (OpenAI/Gemini), or serve the embedder from a separate LM
#     Studio / vLLM instance.
# EMBEDDINGS_ENABLED=false
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=768
# EMBEDDING_BATCH_SIZE=20

# ── Advanced Model Settings ─────────────────────────────
# EXTRACTION_TEMPERATURE=0.2
# NARRATIVE_TEMPERATURE=0.5
# CHAT_MODEL=gemini/gemini-2.5-flash
# SUBAGENT_MODEL=gemini/gemini-2.5-flash

# ── Auth Settings ───────────────────────────────────────
# AUTH_PROVIDER=local
# JWT_EXPIRY_HOURS=720

# ── Model Discovery ────────────────────────────────────
# MODEL_DISCOVERY=on
# MODEL_CACHE_TTL=3600
# OLLAMA_API_BASE=http://localhost:11434
# LOCAL_API_BASE=http://localhost:1234

# ── Model Naming Convention ────────────────────────────
# All model IDs use a provider prefix:
#   Direct API:   gemini/gemini-2.5-flash, openai/gpt-4o, anthropic/claude-sonnet-4-6
#   OpenRouter:   openrouter/mistralai/mistral-large, openrouter/deepseek/deepseek-r1
#   Local (LM Studio/vLLM): local/mistralai/ministral-3-14b, local/qwen/qwen3-30b
#   Ollama:       ollama_chat/llama3.1
#
# The "local/" prefix avoids collision with cloud OpenAI models when
# LM Studio model names contain slashes (e.g. mistralai/ministral-3-14b).
# Set LOCAL_API_BASE above to your LM Studio / vLLM server address.

# ── CORS (adjust for your frontend URL) ─────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
