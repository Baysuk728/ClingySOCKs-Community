# ─────────────────────────────────────────────────────────
# ClingySOCKs — Self-Hosted Configuration
# ─────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# Only DATABASE_URL and at least one LLM API key are required.



# Edition controls which features are enabled:
#   "community" = core memory + chat + harvest + TTS (default)
#   "standard"  = + mood, decay, preferences, graph
#   "pro"       = + dreams, imperfection, heartbeat, agent tasks
#   "full"      = everything
EDITION=community

# ── Database (REQUIRED) ──────────────────────────────────
# PostgreSQL with pgvector extension.
# Railway: Use the $DATABASE_URL variable from your Railway PostgreSQL service.
DATABASE_URL=postgresql://user:password@localhost:5432/clingysocks_memory

# ── Security ─────────────────────────────────────────────
# API key for backend access (leave empty to disable auth in dev)
MEMORY_API_KEY=

# JWT secret for local auth tokens (auto-generated if empty, set for production)
JWT_SECRET=

# Encryption key for API keys stored in DB (64 hex chars or passphrase)
ENCRYPTION_KEY=

# Set to true to refuse startup without ENCRYPTION_KEY and JWT_SECRET
# REQUIRE_SECRETS=false

# ── LLM API Keys ────────────────────────────────────────
# Set at least one. You can also add keys via the Settings UI.
# GEMINI_API_KEY=your-gemini-key
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
# XAI_API_KEY=your-xai-key
# OPENROUTER_API_KEY=your-openrouter-key

# ── Model Configuration ─────────────────────────────────
# Models used by the harvest pipeline. These run in the BACKGROUND and are
# independent of the chat persona model.
#
# ⚠️  LM Studio users: LM Studio loads one model at a time. If these pipeline
#     models differ from your persona's chat model, LM Studio will thrash —
#     unload the chat model, load the pipeline model, then swap back — each
#     time a harvest runs. Point all four (NARRATIVE / EXTRACTION / SYNTHESIS
#     / EMBEDDING) at the SAME local model you chat with, or at a model you
#     keep pre-loaded on a second LM Studio instance. Same applies to
#     EMBEDDING_MODEL below.
NARRATIVE_MODEL=gemini/gemini-2.5-flash
EXTRACTION_MODEL=gemini/gemini-2.5-flash
SYNTHESIS_MODEL=gemini/gemini-2.5-flash

# ── TTS (Optional) ──────────────────────────────────────
# ELEVENLABS_API_KEY=your-elevenlabs-key
# GOOGLE_TTS_API_KEY=your-google-tts-key
# LOCAL_TTS_URL=http://localhost:8880

# ── Web Search (Optional — powers the WebSearchMCP tool) ─
# Lets the agent search the web and fetch pages. Set ONE provider key.
# If no key is set, the search tool returns a "not configured" message
# (page fetching via fetch_webpage still works without a key).
# Provider selection (exa | tavily | brave | serpapi). Exa is recommended.
# SEARCH_PROVIDER=exa
# EXA_API_KEY=your-exa-key
# TAVILY_API_KEY=your-tavily-key
# BRAVE_SEARCH_API_KEY=your-brave-key
# SERPAPI_KEY=your-serpapi-key

# ── Pipeline Settings ───────────────────────────────────
MAX_CHUNK_CHARS=50000
TIME_GAP_HOURS=6
MAX_OUTPUT_TOKENS=16384

# ── Embedding (Optional — enables semantic search) ──────
# ⚠️  LM Studio users: see note above NARRATIVE_MODEL. If EMBEDDING_MODEL
#     points at a local embedder while your chat persona uses a different
#     local model, LM Studio will unload the chat model to load the embedder
#     after every harvest. Either disable embeddings, use an API-hosted
#     embedder (OpenAI/Gemini), or serve the embedder from a separate LM
#     Studio / vLLM instance.
# EMBEDDINGS_ENABLED=false
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=768
# EMBEDDING_BATCH_SIZE=20

# ── Advanced Model Settings ─────────────────────────────
# EXTRACTION_TEMPERATURE=0.2
# NARRATIVE_TEMPERATURE=0.5
# CHAT_MODEL=gemini/gemini-2.5-flash
# SUBAGENT_MODEL=gemini/gemini-2.5-flash

# ── Auth Settings ───────────────────────────────────────
# AUTH_PROVIDER=local
# JWT_EXPIRY_HOURS=720

# ── Model Discovery ────────────────────────────────────
# MODEL_DISCOVERY=on
# MODEL_CACHE_TTL=3600
# OLLAMA_API_BASE=http://localhost:11434
# LOCAL_API_BASE=http://localhost:1234

# ── Model Naming Convention ────────────────────────────
# All model IDs use a provider prefix:
#   Direct API:   gemini/gemini-2.5-flash, openai/gpt-4o, anthropic/claude-sonnet-4-6
#   OpenRouter:   openrouter/mistralai/mistral-large, openrouter/deepseek/deepseek-r1
#   Local (LM Studio/vLLM): local/mistralai/ministral-3-14b, local/qwen/qwen3-30b
#   Ollama:       ollama_chat/llama3.1
#
# The "local/" prefix avoids collision with cloud OpenAI models when
# LM Studio model names contain slashes (e.g. mistralai/ministral-3-14b).
# Set LOCAL_API_BASE above to your LM Studio / vLLM server address.

# ── CORS (adjust for your frontend URL) ─────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
