{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "services": {
    "backend": {
      "build": {
        "dockerfilePath": "memory/Dockerfile",
        "watchPatterns": ["memory/**"]
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "numReplicas": 1
      },
      "networking": {
        "serviceDomain": {},
        "tcpProxies": {}
      },
      "variables": {
        "DATABASE_URL": "${{postgres.DATABASE_URL}}",
        "EDITION": "community",
        "AUTH_PROVIDER": "local",
        "MEMORY_API_KEY": "",
        "OPENROUTER_API_KEY": {
          "description": "Your OpenRouter API key (get one at https://openrouter.ai/keys). This is the only key needed to get started!",
          "required": false
        },
        "GEMINI_API_KEY": {
          "description": "Google Gemini API key (optional — needed for Voice Mode)",
          "required": false
        },
        "OPENAI_API_KEY": {
          "description": "OpenAI API key (optional — needed for embeddings/semantic search)",
          "required": false
        },
        "ANTHROPIC_API_KEY": {
          "description": "Anthropic API key (optional)",
          "required": false
        },
        "ELEVENLABS_API_KEY": {
          "description": "ElevenLabs API key (optional — for premium TTS voices)",
          "required": false
        },
        "EMBEDDINGS_ENABLED": "false",
        "CORS_ORIGINS": "${{frontend.RAILWAY_PUBLIC_DOMAIN:+https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}}}",
        "JWT_SECRET": {
          "description": "Secret for JWT tokens (auto-generated if empty)",
          "required": false
        },
        "ENCRYPTION_KEY": {
          "description": "Encryption key for stored API keys (auto-generated if empty)",
          "required": false
        }
      }
    },
    "frontend": {
      "build": {
        "dockerfilePath": "frontend/Dockerfile",
        "watchPatterns": ["frontend/**"]
      },
      "deploy": {
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "numReplicas": 1
      },
      "networking": {
        "serviceDomain": {},
        "tcpProxies": {}
      },
      "variables": {
        "VITE_MEMORY_API_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}"
      }
    },
    "postgres": {
      "plugin": "postgresql",
      "variables": {}
    }
  }
}
